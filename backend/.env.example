# ─────────────────────────────────────────────────────────────
#  NSE Alert App — Environment Variables
#  1. Copy this file:   cp .env.example .env
#  2. Fill in your values below
#  3. NEVER commit .env to GitHub (it's in .gitignore)
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Your frontend URL (for CORS)
# Local development:
FRONTEND_URL=http://localhost:3000
# Production example:
# FRONTEND_URL=https://your-app.vercel.app

# ── WhatsApp via CallMeBot (FREE forever) ─────────────────────
# Steps to get your key:
#   1. Save +34 644 59 77 58 in your WhatsApp contacts
#   2. Send:  I allow callmebot to send me messages
#   3. You receive your API key in seconds
#   4. Paste it below
CALLMEBOT_API_KEY=YOUR_CALLMEBOT_KEY

# ── SMS via Android Phone Gateway (FREE forever) ──────────────
# Steps to get your URL:
#   1. Install "SMS Gateway for Android" from Play Store
#   2. Open app → note the IP shown (e.g. 192.168.1.5:8080)
#   3. Set a username and password in the app settings
#   4. Fill in below
SMS_GATEWAY_URL=http://YOUR_PHONE_IP:8080
SMS_GATEWAY_USER=admin
SMS_GATEWAY_PASS=admin
